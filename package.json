{
  "name": "mymailclaw",
  "version": "0.1.0",
  "description": "Email scanner, categorizer, and cleaner CLI",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/psandis/mymailclaw.git"
  },
  "homepage": "https://github.com/psandis/mymailclaw",
  "type": "module",
  "bin": {
    "mmclaw": "dist/cli.js"
  },
  "files": [
    "dist",
    "data"
  ],
  "scripts": {
    "cli": "node dist/cli.js",
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "test": "vitest run",
    "lint": "biome check",
    "format": "biome format --write",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "email",
    "gmail",
    "imap",
    "mail",
    "inbox",
    "cleanup",
    "cli",
    "openclaw",
    "mmclaw",
    "categorize",
    "scanner"
  ],
  "author": "psandis",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "imap-simple": "^5.1.0",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/better-sqlite3": "^7.6.13",
    "@types/imap-simple": "^4.2.10",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
